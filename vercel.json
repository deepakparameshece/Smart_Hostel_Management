{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/api/src/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/api/src/server.js"
    },
    {
      "source": "/api-docs/(.*)",
      "destination": "/apps/api/src/server.js"
    },
    {
      "source": "/api-docs",
      "destination": "/apps/api/src/server.js"
    },
    {
      "source": "/health",
      "destination": "/apps/api/src/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/apps/api/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/$1"
    }
  ]
}
